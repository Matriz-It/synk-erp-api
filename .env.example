# Application
NODE_ENV=development
APP_PORT=3000
APP_SECRET=change_me_to_a_strong_random_secret

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=synk_erp

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_smtp_user
MAIL_PASS=your_smtp_pass
MAIL_FROM=noreply@synkerp.com

# 2FA
TOTP_APP_NAME=SynkERP

# Invite / Password reset token TTL (em horas)
INVITE_TOKEN_TTL_HOURS=48
RESET_TOKEN_TTL_HOURS=2
